{
  "name": "instant-messenger",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev:relay": "turbo run dev --filter=relay-server",
    "dev:desktop": "turbo run dev --filter=desktop",
    "build": "turbo run build",
    "build:relay": "turbo run build --filter=relay-server",
    "build:desktop": "turbo run build --filter=desktop",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
