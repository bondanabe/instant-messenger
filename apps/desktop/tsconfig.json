{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "jsx": "react",
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@im/core": ["../../packages/core/src/index.ts"],
      "@im/db-schema": ["../../packages/db-schema/src/index.ts"]
    }
  },
  "include": [
    "src/**/*",
    "../../packages/core/src/**/*",
    "../../packages/db-schema/src/**/*"
  ],
  "exclude": ["dist", "node_modules"]
}
