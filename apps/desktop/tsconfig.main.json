{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react",
    "lib": ["ES2022"],
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true
  },
  "include": [
    "src/main/**/*"
  ],
  "exclude": ["dist", "node_modules"]
}
