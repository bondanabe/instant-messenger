{
  "name": "desktop",
  "version": "1.0.0",
  "description": "Instant Messenger — encrypted desktop chat app",
  "author": {
    "name": "bondanabe",
    "email": "bondanabe@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bondanabe/instant-messenger.git"
  },
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "concurrently -n main,vite,electron \"tsc -p tsconfig.main.json -w\" \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "tsc -p tsconfig.main.json && vite build",
    "build:dist": "electron-builder",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@im/core": "workspace:*",
    "@im/crypto": "workspace:*",
    "@im/db-schema": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.38.3",
    "electron-is-dev": "^3.0.1",
    "electron-updater": "^6.8.3",
    "socket.io-client": "^4.8.1",
    "uuid": "^11.0.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "node": ">=20"
  }
}
